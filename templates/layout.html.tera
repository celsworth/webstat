<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site_name }} - Web Statistics</title>
  <link rel="stylesheet" href="{{ assets_path }}/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1>{{ site_name }}</h1>
      <nav>
        <a href="{{ overview_path }}">Overview</a>
      </nav>
    </div>
  </header>

  <script src="{{ assets_path }}/chart.min.js"></script>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>Generated by <strong>Webstat</strong> on {{ generated_at }}</p>
    </div>
  </footer>

  <script src="{{ assets_path }}/app.js"></script>
</body>
</html>
